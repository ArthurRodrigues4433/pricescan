# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env nunca deve ser commitado no repositório.

# Gere uma nova chave em: https://djecrety.ir/  ou  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=sua-secret-key-aqui

# "True" para desenvolvimento, "False" para produção
DEBUG=True

# Somente Windows — caminho para o executável do Tesseract instalado na sua máquina
# Em Linux/macOS pode deixar em branco (binário já está no PATH)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_LANG=por
