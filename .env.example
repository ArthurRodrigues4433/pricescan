# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env nunca deve ser commitado no repositório.

# Gere uma nova chave em: https://djecrety.ir/  ou  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=sua-secret-key-aqui

# "true" para desenvolvimento, "false" para produção
DEBUG=true

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1

# Origens confiáveis para CSRF em produção (separadas por vírgula)
# CSRF_TRUSTED_ORIGINS=https://seu-dominio.com

# --- PostgreSQL ---
POSTGRES_DB=pricescan
POSTGRES_USER=pricescan
POSTGRES_PASSWORD=sua-senha-segura-aqui
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- DigitalOcean Spaces (S3-compatible) ---
# Deixe DO_SPACES_BUCKET vazio para usar filesystem local (dev)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_MEDIA_LOCATION=media

# --- Gunicorn ---
GUNICORN_WORKERS=3

# --- Email (em dev usa console; em prod configure SMTP) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=seu@email.com
# EMAIL_HOST_PASSWORD=sua-app-password
# DEFAULT_FROM_EMAIL=noreply@pricescan.com

# --- Redis (cache + rate limiting) ---
# Deixe vazio para usar cache em memória local (dev)
# REDIS_URL=redis://redis:6379/1

# --- Tesseract OCR ---
# Somente Windows — caminho para o executável do Tesseract instalado na sua máquina
# Em Linux/macOS/Docker pode deixar em branco (binário já está no PATH)
TESSERACT_CMD=
TESSERACT_LANG=por
